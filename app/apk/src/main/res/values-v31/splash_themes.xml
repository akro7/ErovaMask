<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.WeaveMagisk.Splash.LightBase" parent="Theme.SplashScreen">
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_weavemask_inset</item>
        <item name="windowSplashScreenBackground">#F2F2F7</item> <item name="postSplashScreenTheme">@style/Theme.Foundation.Light</item>
        <item name="windowSplashScreenIconSize">108dp</item>
    </style>

    <style name="Theme.WeaveMagisk.Splash.DarkBase" parent="Theme.SplashScreen">
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_weavemask_inset</item>
        <item name="windowSplashScreenBackground">@color/splash_window_background_night</item>
        <item name="postSplashScreenTheme">@style/Theme.Foundation</item>
        <item name="windowSplashScreenIconSize">108dp</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.WeaveMagisk.Splash.MonetSystem.Light" parent="Theme.WeaveMagisk.Splash.LightBase">
        <item name="windowSplashScreenBackground">@android:color/system_accent2_10</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.WeaveMagisk.Splash.MonetSystem.Dark" parent="Theme.WeaveMagisk.Splash.DarkBase">
        <item name="windowSplashScreenBackground">@color/splash_window_background_night</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.WeaveMagisk.Splash.MonetSystem" parent="Theme.WeaveMagisk.Splash.MonetSystem.Light" />

</resources>
